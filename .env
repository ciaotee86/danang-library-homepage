# --- CẤU HÌNH SERVER ---
PORT=3000

# --- CẤU HÌNH XÁC THỰC GOOGLE OAUTH ---
# Để lấy Client ID: Truy cập https://console.cloud.google.com/
# Tạo dự án mới -> credentials -> OAuth client ID (Web application)
# Thêm authorized redirect URI: http://localhost:3000 và tên miền deploy thật của bạn.
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE.apps.googleusercontent.com

# --- CẤU HÌNH CỔNG THANH TOÁN MOMO ---
# Điền thông tin tài khoản Doanh nghiệp/Merchant MoMo của bạn.
# Nếu dùng Sandbox thử nghiệm, bạn có thể đăng ký tài khoản test tại MoMo Developer.
MOMO_PARTNER_CODE=MOMO_PARTNER_CODE_HERE
MOMO_ACCESS_KEY=MOMO_ACCESS_KEY_HERE
MOMO_SECRET_KEY=MOMO_SECRET_KEY_HERE
# Endpoint test của Momo: https://test-payment.momo.vn/v2/gateway/api/create
MOMO_API_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create

# --- CẤU HÌNH CHUYỂN KHOẢN NGÂN HÀNG VIETQR ---
# Bank ID: Viết hoa mã ngân hàng theo chuẩn Napas (ví dụ: MB, ICB cho VietinBank, VCB, BIDV, ACB, TCB)
# Danh sách mã ngân hàng chi tiết: https://vietqr.io/danh-sach-ma-bin-ngan-hang/
BANK_ID=MB
BANK_ACCOUNT_NUMBER=0905123456
BANK_ACCOUNT_NAME=NGUYEN VAN THU THU
